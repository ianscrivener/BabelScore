# OpenAI API Key
OPENAI_API_KEY=sk-proj-...

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API Key
GEMINI_API_KEY=...

# OpenRouter API Key
OPENROUTER_API_KEY=sk-or-v1-...

# Alibaba Cloud API Key
DASHSCOPE_API_KEY=sk-...

# Bytedance API Key
ARK_API_KEY=...

# Portkey API Key
PORTKEY_API_KEY=

# Eden AI API Key
EDEN_AI_API_KEY


