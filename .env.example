# BabelScore Environment Variables
# Copy this file to .env and fill in your values.
# Please ENSURE .env is never committed to version control 

# =============================================================================
# 1. TEST CORPUS
# URLs or paths to parallel corpus data sources
# =============================================================================

# FLORES-200 dataset (auto-downloaded by babelscore if missing)
# FLORES_200_BASE_URL=https://huggingface.co/datasets/facebook/flores

# Custom remote corpus (CSV or TSV, must match expected column format)
# CORPUS_URL=

# =============================================================================
# 2. TRANSLATOR MODELS (LLMs under test)
# =============================================================================

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (via OpenAI-compatible wrapper)
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# OpenRouter (access to many models via one key)
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local models — no key needed)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Together AI
# TOGETHER_API_KEY=
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# Groq
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# =============================================================================
# 3. JUDGE MODELS
# =============================================================================

# Anthropic (primary judge)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# OpenAI (secondary judge)
# OPENAI_API_KEY=  # already set above if using OpenAI as translator too

# Google Gemini (via OpenAI-compatible endpoint)
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
